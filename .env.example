# Auth server
PORT=3001
JWT_SECRET=change-this-to-a-long-random-secret
ADMIN_EMAIL=usmankhan14700@gmail.com
ADMIN_PASSWORD=admin123

# ─── Supabase (required for Vercel / production) ───
# 1. https://supabase.com/dashboard → New project
# 2. SQL Editor → paste supabase/schema.sql → Run
# 3. Settings → API → copy Project URL + Secret key below
# 4. Run: npm run setup:supabase
# Keep USE_FILE_STORAGE=false so laptop + mobile share the same cloud database.
# USE_FILE_STORAGE=true
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key

# Frontend URL (for CORS)
CLIENT_ORIGIN=http://localhost:5173

# Cloud sync — allow phones on any network (mobile data, different Wi‑Fi)
CORS_ALLOW_ALL=true

# Public URL (optional — Vercel sets VERCEL_URL automatically)
# PUBLIC_SERVER_URL=https://your-app.vercel.app

# Frontend — API base URL (baked into web/APK build if set)
# VITE_API_URL=https://your-app.vercel.app
# VITE_DEFAULT_CLOUD_URL=https://your-app.vercel.app

# Email OTP + admin registration alerts (Gmail — create App Password at https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=usmankhan14700@gmail.com
SMTP_PASS=your-gmail-app-password-here
SMTP_FROM=Chai Khata <usmankhan14700@gmail.com>

# Daily subscription expiry reminders (Vercel Cron — 9:00 AM Pakistan time)
# Generate a random string for production: openssl rand -hex 32
CRON_SECRET=change-me-cron-secret
REMINDER_TIMEZONE=Asia/Karachi

# ─── Email on Vercel (patiwala.pk) — use FREE Brevo (recommended) ───
# Gmail SMTP ports 587/465 are BLOCKED on Vercel serverless.
#
# Brevo free plan: 300 emails/day, no paid domain needed.
# 1. Sign up at https://www.brevo.com (free)
# 2. Settings → SMTP & API → Generate API key
# 3. Senders & IP → Add sender → usmankhan14700@gmail.com → verify via inbox link
# 4. Add to Vercel env (Production):
BREVO_API_KEY=xkeysib-your-brevo-api-key
BREVO_FROM=Patiwala <usmankhan14700@gmail.com>
#
# Optional: remove RESEND_API_KEY from Vercel if you switch to Brevo.

# Alternative: Resend (free tier limited — extra domains require paid plan)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Patiwala <onboarding@resend.dev>

# ─── Twilio SMS OTP ───
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM=+1234567890

# Subscription plan prices (Rs)
SUBSCRIPTION_MONTHLY_PRICE=1000
SUBSCRIPTION_SIX_MONTH_PRICE=5000
SUBSCRIPTION_YEARLY_PRICE=9000
